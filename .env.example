# ─── Aapka Credit — Environment Variables ─────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git (it is already in .gitignore)

# ── Google Analytics 4 ─────────────────────────────────────────────────────────
# Steps to get your GA4 Measurement ID:
# 1. Go to https://analytics.google.com
# 2. Create a new GA4 property for aapkacredit.com
# 3. Admin → Data Streams → Add stream → Web
# 4. Copy the Measurement ID (format: G-XXXXXXXXXX)
# 5. Paste it below and in Vercel/hosting environment variables
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Google Search Console ──────────────────────────────────────────────────────
# Steps to get your GSC verification code:
# 1. Go to https://search.google.com/search-console
# 2. Add property → URL prefix → https://aapkacredit.com
# 3. Verify via HTML tag → copy the "content" value from the meta tag
# 4. Paste only the content value below (not the full tag)
# Example: NEXT_PUBLIC_GSC_CODE=AbCdEfGhIjKlMnOpQrStUvWxYz1234567890AbCd
NEXT_PUBLIC_GSC_CODE=TODO_REPLACE_WITH_GSC_VERIFICATION_CODE

# ── Site Configuration ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aapkacredit.com

# ── Contact / Support Email ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPPORT_EMAIL=support@aapkacredit.com
